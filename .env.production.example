# Copy this file to `.env` next to docker-compose.production.yml and fill in real
# values. `.env` is gitignored — never commit it.

# SQL Server SA password for the `db` service.
# Complexity required by SQL Server: at least 8 characters, containing 3 of the
# 4 character classes (uppercase letters, lowercase letters, digits, symbols).
# Generate one with, e.g.:
#   openssl rand -base64 18 | tr -d '\n'; echo '#1'
MSSQL_SA_PASSWORD=

# JWT signing key for the `api` service, must be at least 32 characters.
# Non-Development environments (this is Production) refuse to start with the
# bundled dev placeholder. Generate with:
#   openssl rand -base64 48
JWT_SECRET_KEY=

# Cloudflare Tunnel token for the `cloudflared` service.
# Get it from Cloudflare Zero Trust -> Networks -> Tunnels -> Create a tunnel
# (Cloudflared connector type, name it e.g. "dorent-production") -> Install and
# run a connector. Cloudflare shows an install command containing
# `... tunnel run --token <TOKEN>` — copy only the <TOKEN> part here.
CLOUDFLARE_TUNNEL_TOKEN=

# --- First-boot admin account ---
# Production starts from an empty database (no dev seed, unlike staging) — without
# these two values there is NO admin account at all. On startup, if both are set
# and no user with this email exists yet, the app creates one Admin-role user
# (see AdminBootstrapRunner). This is idempotent and safe to leave in place across
# restarts, but for good hygiene: after your first successful login as this admin,
# consider blanking these two values and restarting the stack, so the credentials
# no longer sit in a plaintext .env file on disk.
#
# Password rule enforced by the app (same as the public registration endpoint,
# RegisterRequest.Password): 8-128 characters. No additional complexity is
# enforced by the app itself, but this is your platform's initial admin account —
# use a long, random, unique password. Generate one with, e.g.:
#   openssl rand -base64 24
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# --- Initial catalogue (demo showcase content) ---
# Production starts from an empty database — no categories, no listings, nothing for a
# visitor to see. If enabled, on startup the app idempotently creates ONE dedicated
# "showcase owner" account plus the platform's curated catalogue of Approved toy listings
# and their images (see DemoContentBootstrapRunner). This is for the initial public
# catalogue only — it never creates any other account (no shared/demo logins), and never
# creates bookings, reviews, or chats. Safe to leave enabled indefinitely: idempotent, and
# additive-only — it will never modify or delete a listing once created, including edits
# the showcase owner later makes to it through the normal owner UI.
#
# BOOTSTRAP_DEMO_CONTENT_ENABLED must be exactly "true" (case-insensitive) to run anything;
# any other value (including unset) is a no-op, same as leaving the owner fields blank.
#
# BOOTSTRAP_DEMO_OWNER_EMAIL / BOOTSTRAP_DEMO_OWNER_PASSWORD are real login credentials for
# a real account on a public site — this is NOT a shared demo/test password. Password rule
# enforced by the app (same as the public registration endpoint): 8-128 characters, no
# additional complexity enforced by the app itself, but treat this exactly like the admin
# account above: a long, random, unique password you control. Generate one with, e.g.:
#   openssl rand -base64 24
BOOTSTRAP_DEMO_CONTENT_ENABLED=
BOOTSTRAP_DEMO_OWNER_EMAIL=
BOOTSTRAP_DEMO_OWNER_PASSWORD=
