# Copy this file to `.env` next to docker-compose.staging.yml and fill in real
# values. `.env` is gitignored — never commit it.

# SQL Server SA password for the `db` service.
# Complexity required by SQL Server: at least 8 characters, containing 3 of the
# 4 character classes (uppercase letters, lowercase letters, digits, symbols).
# Generate one with, e.g.:
#   openssl rand -base64 18 | tr -d '\n'; echo '#1'
MSSQL_SA_PASSWORD=

# JWT signing key for the `api` service, must be at least 32 characters.
# Non-Development environments refuse to start with the bundled dev placeholder,
# and this stand should not reuse the dev secret either. Generate with:
#   openssl rand -base64 48
JWT_SECRET_KEY=

# Cloudflare Tunnel token for the `cloudflared` service.
# Get it from Cloudflare Zero Trust -> Networks -> Tunnels -> Create a tunnel
# (Cloudflared connector type) -> Install and run a connector. Cloudflare shows
# an install command containing `... tunnel run --token <TOKEN>` — copy only the
# <TOKEN> part (a long base64-looking string) here.
CLOUDFLARE_TUNNEL_TOKEN=
