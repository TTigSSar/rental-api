{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=RentalPlatformDbDev;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "RentalPlatform",
    "Audience": "RentalPlatform.Api",
    "SecretKey": "development-only-secret-key-change-before-shared-use-12345",
    "AccessTokenExpirationMinutes": 60
  },
  "ExternalAuth": {
    "Google": {
      "ValidAudiences": [
        "your-google-client-id.apps.googleusercontent.com"
      ]
    },
    "Apple": {
      "Issuer": "https://appleid.apple.com",
      "JwksUrl": "https://appleid.apple.com/auth/keys",
      "ValidAudiences": [
        "your.apple.client.id"
      ]
    }
  },
  "FileStorage": {
    "ListingsImagesPath": "uploads/listings",
    "ChatAttachmentsPath": "uploads/chat"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://127.0.0.1:4200",
      "https://127.0.0.1:4200"
    ]
  }
}
