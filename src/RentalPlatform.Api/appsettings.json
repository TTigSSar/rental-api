{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=RentalPlatformDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "RentalPlatform",
    "Audience": "RentalPlatform.Api",
    "SecretKey": "",
    "AccessTokenExpirationMinutes": 60
  },
  "ExternalAuth": {
    "Google": {
      "ValidAudiences": [
        "set-google-client-id-in-environment"
      ]
    },
    "Apple": {
      "Issuer": "https://appleid.apple.com",
      "JwksUrl": "https://appleid.apple.com/auth/keys",
      "ValidAudiences": [
        "set-apple-client-id-in-environment"
      ]
    }
  },
  "FileStorage": {
    "ListingsImagesPath": "uploads/listings"
  },
  "AllowedHosts": "*"
}
